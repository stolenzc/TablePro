    "You have unsaved changes to the table structure. Refreshing will discard these changes." : {
      "localizations" : {
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tablo yapısında kaydedilmemiş değişiklikleriniz var. Yenileme bu değişiklikleri siler."
