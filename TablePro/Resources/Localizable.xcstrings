            "value" : "CẢNH BÁO: Bật lại kiểm tra khóa ngoại thất bại: %@. Vui lòng kiểm tra thủ công rằng ràng buộc FK đã được bật."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
