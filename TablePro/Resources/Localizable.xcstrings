        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Khi bật, nhấp vào bảng trong thanh bên sẽ thay thế tab hiện tại nếu không có thay đổi chưa lưu và bạn chưa tương tác với nó (sắp xếp, lọc, v.v.)."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
